# 0xLeverage Terminal — Environment Variables
# Copy this file to .env and fill in the values. The running server reads .env only — not this file.
#   copy .env.example .env  (Windows)  |  cp .env.example .env  (macOS/Linux)
# Never commit .env to git

# ── REQUIRED ─────────────────────────────────────────────────────────

# 0xLeverage protocol API key (shared dapp key — get from the 0xL team)
OXL_API_KEY=A7f9K2xQ4L

# 0xLeverage API base URL
OXL_API_BASE_URL=https://levapi.0xleverage.io


# MySQL / TiDB — Drizzle uses this for the `users` table (OAuth profile rows).
# Production: use a managed DB with TLS, e.g.:
#   DATABASE_URL=mysql://user:pass@host:port/dbname?ssl={"rejectUnauthorized":true}
# Local — Docker: run setup-mysql.bat, then (matches docker/mysql.env + docker-compose):
#   DATABASE_URL=mysql://oxlev:oxlev_dev_password@127.0.0.1:3306/oxlev
DATABASE_URL=mysql://user:pass@host:port/dbname?ssl={"rejectUnauthorized":true}

# Session signing secret — minimum 64 random chars
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=v-GxDIj4sROQV754peWaBlfiXyrx4TIGEPgUmTpWLBj87J19yNjtw9LSRCV8ebOMEbsESCu7h5rUM_Q7be2XDw
NODE_ENV=development

# ── OPTIONAL BUT RECOMMENDED ────────────────────────────────────────

# Solana RPC endpoint — defaults to public mainnet-beta if unset
# Public RPC is rate-limited; use Helius, QuickNode, or Triton for production
# Get from: https://www.helius.dev/
VITE_SOLANA_RPC_URL=

# CoinGecko Pro API key — avoids free tier rate limits under load
# Get from: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Jupiter API key — optional, uses free v2 endpoint if not set
# Set for v3 with higher rate limits (600 req/min)
# Get from: https://portal.jup.ag/
JUPITER_API_KEY=jup_3eb8d404833458984dcb5b3ce5c63fb18f9c5a239abb18edddea6afb3faa9631

# Birdeye API key — used for real-time orderbook / trade data
# Get from: https://birdeye.so/developer
BIRDEYE_API_KEY=

# Server port (default: 3000)
PORT=3000

# ── OAUTH (only needed if using platform auth, not wallet-only) ──────

VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# ── PLATFORM / MANAGED HOSTING ───────────────────────────────────────

OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── ANALYTICS (optional) ─────────────────────────────────────────────

VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── BRANDING ─────────────────────────────────────────────────────────

VITE_APP_TITLE=0xLeverage
VITE_APP_LOGO=
